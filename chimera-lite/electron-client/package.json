{
  "name": "chimera-lite-client",
  "version": "1.0.0",
  "productName": "Chimera Lite",
  "description": "Realtime face swap client for Project Chimera Lite",
  "author": "Saint Herald Faust",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable",
    "dist:installer": "electron-builder --win nsis",
    "pack": "electron-builder --win dir"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.purplefinger.chimeralite",
    "productName": "Chimera Lite",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".env.example",
        "to": ".env.example"
      },
      {
        "from": "droidcamdrivers",
        "to": "droidcamdrivers"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "publisherName": "Saint Herald Faust",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Chimera-Lite-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "Chimera Lite",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
