# Purplefinger client config (optional — you can also set these in the app's
# Settings panel). Copy to `.env` and fill in.

# URL of the GPU inference node you are running (see gpu-node/). The client
# connects directly to it over WebSocket — bring your own GPU.
#   local GPU:  ws://127.0.0.1:8765
#   remote/RunPod: ws://<host-or-ip>:<port>
GPU_URL=ws://127.0.0.1:8765

# Local port for the OBS Browser Source output (http://localhost:<port>)
OBS_PORT=7891
